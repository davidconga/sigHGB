{
  "expo": {
    "name": "SIGHGB",
    "slug": "sighgb",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "android": {
      "package": "ao.hgb.sighgb",
      "permissions": [
        "NOTIFICATIONS",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#143d6b",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "ios": {
      "bundleIdentifier": "ao.hgb.sighgb",
      "supportsTablet": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-status-bar",
      [
        "expo-notifications",
        {
          "color": "#1f5fa6"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permite usar Face ID para entrar no SIGHGB."
        }
      ]
    ],
    "owner": "davidconga",
    "extra": {
      "eas": {
        "projectId": "da8e7473-f87d-4587-800e-9837422a89b4"
      }
    }
  }
}
